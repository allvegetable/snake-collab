    export ANTHROPIC_BASE_URL ANTHROPIC_API_KEY
    if [[ -n "${HTTPS_PROXY:-}" ]]; then
      export HTTPS_PROXY
    fi
    timeout "${CMD_TIMEOUT}s" claude -p --dangerously-skip-permissions "$mk2_prompt"
  ) >"$mk2_out" 2>>"$round_log"
  mk2_exit=$?
  set -e

  {
    echo "[MK2_EXIT] $mk2_exit"
    echo "[MK2_OUTPUT]"
    cat "$mk2_out"
    echo
  } >> "$round_log"

